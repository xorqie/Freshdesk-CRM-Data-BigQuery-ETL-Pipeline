# Copy this file to `.env` and fill in your own values.
# Never commit your actual `.env` file - it is already excluded via .gitignore.

# --- Freshdesk ---
# Your Freshdesk subdomain, e.g. for https://acme.freshdesk.com it's "acme"
FRESHDESK_DOMAIN=your-subdomain
# Generate this from Freshdesk: Profile Settings -> API Key
FRESHDESK_API_KEY=your-freshdesk-api-key

# --- Google BigQuery ---
BQ_PROJECT_ID=your-gcp-project-id
BQ_DATASET_ID=freshdesk
BQ_TICKETS_TABLE=tickets
BQ_AGENTS_TABLE=agents
BQ_CSAT_TABLE=csat

# Path to your GCP service account JSON key file (needs BigQuery Data Editor
# and BigQuery Job User roles at minimum)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json
